# Maintainer: recurl team
# AUR binary package for recurl - prebuilt binaries

pkgname=recurl-bin
pkgver=0.1.2
pkgrel=1
pkgdesc="Drop-in curl replacement with automatic anti-bot bypass (prebuilt binary)"
arch=('x86_64')
url="https://github.com/neul-labs/recurl"
license=('MIT')
depends=('curl' 'openssl')
optdepends=(
    'chromium: for JS preflight (auto-downloaded if not present)'
    'google-chrome: alternative to chromium for JS preflight'
)
provides=('recurl')
conflicts=('recurl' 'recurl-git')
source_x86_64=("https://github.com/neul-labs/recurl/releases/download/v$pkgver/recurl-linux-x86_64.tar.gz")
sha256sums_x86_64=('SKIP')

package() {
    # Install binaries
    install -Dm755 "bin/recurl" "$pkgdir/usr/bin/recurl"
    install -Dm755 "bin/recurld" "$pkgdir/usr/bin/recurld"

    # Install license
    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE" || true

    # Install documentation
    install -Dm644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md" || true
}

post_install() {
    echo "recurl installed! To use as a drop-in curl replacement:"
    echo "  echo 'alias curl=recurl' >> ~/.bashrc"
    echo ""
    echo "Or use recurl directly:"
    echo "  recurl https://example.com"
    echo ""
    echo "For JS preflight with warm browsers, start the daemon:"
    echo "  recurld start"
}
