# Maintainer: recurl team
# AUR package for recurl - drop-in curl replacement with anti-bot bypass

pkgname=recurl
pkgver=0.1.2
pkgrel=1
pkgdesc="Drop-in curl replacement with automatic anti-bot bypass"
arch=('x86_64' 'aarch64')
url="https://github.com/user/recurl"
license=('MIT')
depends=('curl' 'openssl')
makedepends=('cargo' 'git')
optdepends=(
    'chromium: for JS preflight (auto-downloaded if not present)'
    'google-chrome: alternative to chromium for JS preflight'
)
provides=('recurl')
conflicts=('recurl-bin' 'recurl-git')
source=("$pkgname-$pkgver.tar.gz::https://github.com/user/recurl/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --release --locked
    cargo build --release --locked --bin recurld --features daemon
}

check() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    cargo test --release --locked
}

package() {
    cd "$pkgname-$pkgver"

    # Install binaries
    install -Dm755 "target/release/recurl" "$pkgdir/usr/bin/recurl"
    install -Dm755 "target/release/recurld" "$pkgdir/usr/bin/recurld"

    # Install license
    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"

    # Install documentation
    install -Dm644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 "docs/installation.md" "$pkgdir/usr/share/doc/$pkgname/installation.md"
    install -Dm644 "docs/cli.md" "$pkgdir/usr/share/doc/$pkgname/cli.md"

    # Install shell completions (if available)
    # install -Dm644 "completions/recurl.bash" "$pkgdir/usr/share/bash-completion/completions/recurl"
    # install -Dm644 "completions/recurl.zsh" "$pkgdir/usr/share/zsh/site-functions/_recurl"
    # install -Dm644 "completions/recurl.fish" "$pkgdir/usr/share/fish/vendor_completions.d/recurl.fish"
}
