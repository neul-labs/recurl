#!/usr/bin/env node
const { spawn } = require("child_process");
const path = require("path");

const binaryDir = path.join(__dirname, "__bin__");
const binary = path.join(binaryDir, "recurl");

const child = spawn(binary, process.argv.slice(2), {
  stdio: "inherit",
  env: process.env,
});

child.on("exit", (code) => {
  process.exit(code ?? 0);
});
